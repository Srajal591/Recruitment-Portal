{
  "name": "recruitment-portal-backend",
  "version": "1.0.0",
  "description": "Government Recruitment & Examination Management Portal - Backend API",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node scripts/start-services.js",
    "dev": "node scripts/start-services.js",
    "seed": "node scripts/seed-admin.js",
    "kill-ports": "powershell -Command \"@(5000,5001,5002,5003) | ForEach-Object { $p = (Get-NetTCPConnection -LocalPort $_ -ErrorAction SilentlyContinue).OwningProcess; if ($p) { Stop-Process -Id $p -Force -ErrorAction SilentlyContinue; Write-Host \\\"Freed port $_\\\" } }\"",
    "lint": "echo \"No linter configured yet\"",
    "gateway": "node apps/api-gateway/server.js",
    "identity": "node apps/identity-service/server.js",
    "recruitment": "node apps/recruitment-service/server.js",
    "communication": "node apps/communication-payment-service/server.js"
  },
  "keywords": [
    "recruitment",
    "government",
    "portal",
    "mern"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "amqplib": "^0.10.4",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.5",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.9"
  }
